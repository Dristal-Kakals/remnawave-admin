# Prometheus scrape config (TEMPLATE) для Remnawave Admin Panel.
#
# Этот файл — шаблон. Реальный конфиг генерируется entrypoint-скриптом
# контейнера prometheus: плейсхолдер __METRICS_AUTH_TOKEN__ заменяется
# значением переменной окружения METRICS_AUTH_TOKEN из .env и кладётся
# в /tmp/prometheus.yml. Если переменная пуста — авторизация уходит
# из конфига и /metrics дёргается без Bearer.
#
# Запуск:  docker compose --profile monitoring up -d
# Доступ:  http://server:9090 (или ${PROMETHEUS_PORT})

global:
  scrape_interval: 15s
  scrape_timeout: 10s
  external_labels:
    instance_name: remnawave-panel

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: remnawave-panel
    metrics_path: /metrics
    static_configs:
      - targets:
          # Port is substituted by entrypoint.sh from WEB_BACKEND_PORT:
          # 8081 in full mode, 8082 when APP_MODE=api (split) — the admin
          # backend moves to 8082 and the collector keeps 8081.
          - remnawave-web-backend:__WEB_BACKEND_PORT__
        labels:
          service: panel
    authorization:
      type: Bearer
      credentials: __METRICS_AUTH_TOKEN__

  - job_name: prometheus
    static_configs:
      - targets:
          - localhost:9090
